datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String?   @default("user")
  password      String?

  // Profile fields
  firstName      String?
  lastName       String?
  documentType   String?
  documentNumber String?
  phone          String?
  gender         String?
  birthDate      DateTime?
  maritalStatus  String?
  hasChildren    Boolean   @default(false)
  childrenCount  Int       @default(0)
  country        String?
  city           String?
  address        String?
  neighborhood   String?
  isActive       Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Red (un usuario solo puede pertenecer a una red)
  networkId   String?
  network     Network? @relation(fields: [networkId], references: [id], onDelete: SetNull)
  networkRole String?  // 'leader' | 'member'
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  colors      Json?    // e.g., { primary: "#0466C8", secondary: "#001845" }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  networks    Network[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===================
// Módulo de Redes
// ===================

model Network {
  id             String   @id @default(cuid())
  name           String
  description    String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Usuarios que pertenecen a esta red (como líderes o miembros)
  users          User[]
}
