datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

// ===================
// Enum de Roles Base
// ===================

enum SystemRole {
  admin
  pastor
  member
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  role          String?      @default("user")  // @deprecated - usar roles[]
  roles         SystemRole[] @default([member])
  password      String?

  // Profile fields
  firstName      String?
  lastName       String?
  documentType   String?
  documentNumber String?
  phone          String?
  gender         String?
  birthDate      DateTime?
  maritalStatus  String?
  hasChildren    Boolean   @default(false)
  childrenCount  Int       @default(0)
  country        String?
  city           String?
  address        String?
  neighborhood   String?
  isActive       Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Red (un usuario solo puede pertenecer a una red)
  networkId   String?
  network     Network? @relation(fields: [networkId], references: [id], onDelete: SetNull)
  networkRole String?  // 'leader' | 'member'

  // Grupos donde es líder
  groupLeaderships GroupLeader[]

  // Reportes creados
  groupReports     GroupReport[]

  // Eventos de calendario creados
  calendarEvents   CalendarEvent[]

  // Áreas de servicio donde es líder
  ledServiceAreas  ServiceAreaLeader[]

  // Áreas donde es voluntario
  volunteerAreas   VolunteerAssignment[]
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  colors      Json?    // e.g., { primary: "#0466C8", secondary: "#001845" }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  networks        Network[]
  groups          Group[]
  groupReports    GroupReport[]
  calendarEvents  CalendarEvent[]
  serviceAreas    ServiceArea[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===================
// Módulo de Redes
// ===================

model Network {
  id             String   @id @default(cuid())
  name           String
  description    String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Usuarios que pertenecen a esta red (como líderes o miembros)
  users          User[]

  // Grupos de esta red
  groups         Group[]
}

// ===================
// Módulo de Grupos
// ===================

model Group {
  id             String   @id @default(cuid())
  name           String
  description    String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relación con Red (obligatoria)
  networkId      String
  network        Network  @relation(fields: [networkId], references: [id], onDelete: Cascade)

  // Organización
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Modalidad: 'virtual' | 'presencial'
  modality       String   @default("presencial")

  // Ubicación (solo para presencial)
  city           String?
  address        String?
  neighborhood   String?

  // Horario de reunión
  meetingDay     String?  // lunes, martes, etc.
  meetingTime    String?  // "19:00"

  // Líderes (many-to-many)
  leaders        GroupLeader[]

  // Reportes de este grupo
  reports        GroupReport[]
}

model GroupLeader {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  createdAt DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

// ===================
// Módulo de Reportes
// ===================

model GroupReport {
  id              String   @id @default(cuid())

  // Fecha de la reunión (solo fecha, sin hora)
  meetingDate     DateTime @db.Date

  // Asistencia
  totalAttendees  Int      // Total asistentes (incluye líderes)
  leadersCount    Int      // Cuántos eran líderes
  visitorsCount   Int      // Cuántos fueron visitas

  // Ofrenda
  reportOffering  Boolean  @default(false)
  offeringAmount  Decimal? @db.Decimal(10, 2)

  // Notas (opcional)
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  reporterId      String   // Usuario que creó el reporte
  reporter        User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([groupId, meetingDate])  // Un reporte por grupo por fecha
}

// ===================
// Módulo de Calendario
// ===================

model CalendarEvent {
  id             String   @id @default(cuid())
  title          String
  description    String?

  // Fechas
  startDate      DateTime
  endDate        DateTime
  allDay         Boolean  @default(false)

  // Categoría: 'culto' | 'evento' | 'reunion' | 'actividad' | 'capacitacion'
  category       String   @default("evento")

  // URL externa opcional (para más info)
  url            String?

  // Ubicación
  location       String?

  // Estado
  isActive       Boolean  @default(true)

  // Visibilidad: 'public' | 'leaders' | 'admin'
  visibility     String   @default("public")

  // Área de servicio asociada (opcional)
  serviceAreaId  String?
  serviceArea    ServiceArea? @relation(fields: [serviceAreaId], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relaciones
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ===================
// Módulo de Áreas de Servicio
// ===================

model ServiceArea {
  id             String   @id @default(cuid())
  name           String
  description    String?
  color          String?  // Color hex para UI
  icon           String?  // Icono remixicon
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relaciones
  leaders        ServiceAreaLeader[]
  volunteers     VolunteerAssignment[]
  events         CalendarEvent[]

  @@unique([organizationId, name])  // Nombre único por organización
}

model ServiceAreaLeader {
  id             String      @id @default(cuid())

  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceAreaId  String
  serviceArea    ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  createdAt      DateTime    @default(now())

  @@unique([userId, serviceAreaId])
}

model VolunteerAssignment {
  id             String      @id @default(cuid())

  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceAreaId  String
  serviceArea    ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  isActive       Boolean     @default(true)
  notes          String?     // Notas sobre el voluntario

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userId, serviceAreaId])
}
