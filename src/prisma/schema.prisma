datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Rol del usuario (FK a Role)
  roleId        String?
  userRole      Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  password      String?

  // Profile fields
  firstName      String?
  lastName       String?
  documentType   String?
  documentNumber String?
  phone          String?
  gender         String?
  birthDate      DateTime?
  maritalStatus  String?
  hasChildren    Boolean   @default(false)
  childrenCount  Int       @default(0)
  country        String?
  city           String?
  address        String?
  neighborhood   String?
  isActive       Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Red (un usuario solo puede pertenecer a una red)
  networkId   String?
  network     Network? @relation(fields: [networkId], references: [id], onDelete: SetNull)
  networkRole String?  // 'leader' | 'member'

  // Grupo (un usuario solo puede pertenecer a un grupo)
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupRole String?  // 'leader' | 'member'

  // Reportes creados
  groupReports     GroupReport[]

  // Eventos de calendario creados
  calendarEvents   CalendarEvent[]
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  colors      Json?    // e.g., { primary: "#0466C8", secondary: "#001845" }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  roles           Role[]
  networks        Network[]
  groups          Group[]
  groupReports    GroupReport[]
  calendarEvents  CalendarEvent[]
}

// ===================
// Módulo de Roles y Permisos
// ===================

model Role {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  hierarchy      Int      // 1 = más poder (Admin=1, Aux=2, Pastor=3, Líder=4, Voluntario=5, Usuario=6)
  isSystem       Boolean  @default(false) // Roles protegidos (Admin, Usuario) no se pueden eliminar
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  permissions    RolePermission[]
  users          User[]
}

model Permission {
  id          String @id @default(cuid())
  module      String // "usuarios", "redes", "grupos", "reportes", "calendario", "configuracion", "roles", "dashboard"
  action      String // "ver", "crear", "editar", "eliminar", "exportar"
  description String // "Ver lista de usuarios"

  roles       RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===================
// Módulo de Redes
// ===================

model Network {
  id             String   @id @default(cuid())
  name           String
  description    String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Usuarios que pertenecen a esta red (como líderes o miembros)
  users          User[]

  // Grupos de esta red
  groups         Group[]
}

// ===================
// Módulo de Grupos
// ===================

model Group {
  id             String   @id @default(cuid())
  name           String
  description    String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relación con Red (obligatoria)
  networkId      String
  network        Network  @relation(fields: [networkId], references: [id], onDelete: Cascade)

  // Organización
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Modalidad: 'virtual' | 'presencial'
  modality       String   @default("presencial")

  // Ubicación (solo para presencial)
  city           String?
  address        String?
  neighborhood   String?

  // Horario de reunión
  meetingDay     String?  // lunes, martes, etc.
  meetingTime    String?  // "19:00"

  // Miembros del grupo (líderes y miembros)
  members        User[]

  // Reportes de este grupo
  reports        GroupReport[]
}

// ===================
// Módulo de Reportes
// ===================

model GroupReport {
  id              String   @id @default(cuid())

  // Fecha de la reunión (solo fecha, sin hora)
  meetingDate     DateTime @db.Date

  // Asistencia
  totalAttendees  Int      // Total asistentes (incluye líderes)
  leadersCount    Int      // Cuántos eran líderes
  visitorsCount   Int      // Cuántos fueron visitas

  // Ofrenda
  reportOffering  Boolean  @default(false)
  offeringAmount  Decimal? @db.Decimal(10, 2)

  // Notas (opcional)
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  reporterId      String   // Usuario que creó el reporte
  reporter        User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([groupId, meetingDate])  // Un reporte por grupo por fecha
}

// ===================
// Módulo de Calendario
// ===================

model CalendarEvent {
  id             String   @id @default(cuid())
  title          String
  description    String?

  // Fechas
  startDate      DateTime
  endDate        DateTime
  allDay         Boolean  @default(false)

  // Categoría: 'culto' | 'evento' | 'reunion' | 'actividad' | 'capacitacion'
  category       String   @default("evento")

  // URL externa opcional (para más info)
  url            String?

  // Ubicación
  location       String?

  // Estado
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relaciones
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
